#!/usr/bin/perl
#
# nfd2nfc — macOS 한글 파일명 자소분리(NFD) → 정상(NFC) 변환기
#
# macOS는 파일명을 NFD(분해형)로 저장합니다. 그래서 한글 파일명이
# 윈도우나 일부 웹 업로드에서 'ㅇㅏㄴㄴㅕㅇ'처럼 자소분리되어 보입니다.
# 이 스크립트는 파일/폴더 이름을 NFC(조합형)로 바꿔 문제를 없앱니다.
# (보이는 글자는 그대로, 내부 유니코드 인코딩만 정규화 — 안전합니다.)
#
# 의존성 없음: macOS 기본 perl 만으로 동작합니다.
#
# 사용법:
#   nfd2nfc [옵션] <파일/폴더 ...>
# 옵션:
#   -n, --dry-run     실제로 바꾸지 않고 바뀔 내용만 미리보기
#       --no-recurse  폴더 안쪽까지 들어가지 않고 지정한 항목만 처리
#       --notify      완료 후 macOS 알림 표시
#   -v, --verbose     변경 내역을 한 줄씩 출력
#   -V, --version     버전 출력
#   -h, --help        도움말

use strict;
use warnings;
use Unicode::Normalize qw(NFC);
use Encode qw(decode_utf8 encode_utf8);
use Getopt::Long qw(GetOptions);

our $VERSION = "1.0.1";

my ($dry, $recurse, $notify, $verbose, $help, $version, $reveal) = (0, 1, 0, 0, 0, 0, 0);
# 대소문자 구분: -v(verbose)와 -V(version)가 섞이지 않도록.
# (Getopt::Long은 기본적으로 대소문자를 무시해 -v/-V를 같은 옵션으로 취급한다)
Getopt::Long::Configure('no_ignore_case');
GetOptions(
    'dry-run|n'  => \$dry,
    'recurse!'   => \$recurse,
    'notify'     => \$notify,
    'reveal'     => \$reveal,
    'verbose|v'  => \$verbose,
    'version|V'  => \$version,
    'help|h'     => \$help,
) or usage(1);

if ($version) { print "nfd2nfc $VERSION\n"; exit 0; }
usage(0) if $help;
usage(1) unless @ARGV;

# 사용자가 선택한 최상위 항목(옵션 제거 후 남은 인자) — 완료 후 Finder에 보여줄 대상
my @inputs = @ARGV;

sub usage {
    my $code = shift // 0;
    print <<'TXT';
nfd2nfc — macOS 한글 파일명 NFD→NFC 변환기

사용법:  nfd2nfc [옵션] <파일/폴더 ...>

옵션:
  -n, --dry-run     미리보기 (실제로 바꾸지 않음)
      --no-recurse  지정한 항목만 처리 (하위 폴더 제외)
      --notify      완료 후 macOS 알림
      --reveal      완료 후 Finder에서 대상 보여주기
  -v, --verbose     변경 내역 출력
  -V, --version     버전 출력
  -h, --help        이 도움말
TXT
    exit $code;
}

# 1) 대상 경로 수집 (바이트 문자열 그대로 다룸 = 파일시스템 안전)
my @targets;
sub collect {
    my ($path) = @_;
    $path =~ s{/+$}{};                 # 끝 슬래시 제거
    return if $path eq '';
    push @targets, $path;
    if ($recurse && -d $path && !-l $path) {
        if (opendir(my $dh, $path)) {
            my @entries = readdir($dh);
            closedir($dh);
            for my $e (@entries) {
                next if $e eq '.' || $e eq '..';
                collect("$path/$e");
            }
        } else {
            warn "열 수 없음: $path ($!)\n";
        }
    }
}
collect($_) for @ARGV;

# 2) 깊은 경로부터 처리(자식 → 부모) 해야 폴더 이름을 바꿔도 경로가 안 깨짐
my @sorted = sort { ($b =~ tr{/}{}) <=> ($a =~ tr{/}{}) } @targets;

# 3) 변환
my ($changed, $skipped) = (0, 0);
for my $p (@sorted) {
    my $i    = rindex($p, '/');
    my $dir  = $i < 0 ? '' : substr($p, 0, $i + 1);
    my $base = $i < 0 ? $p : substr($p, $i + 1);

    # 파일명이 올바른 UTF-8이 아니면 건너뜀
    # (주의: decode_utf8 은 CHECK 인자를 주면 원본 스칼라를 비우므로 사본을 디코드)
    my $u = eval { my $copy = $base; decode_utf8($copy, Encode::FB_CROAK) };
    next unless defined $u;

    my $newbase = encode_utf8(NFC($u));
    next if $newbase eq $base;             # 이미 NFC → 변경 불필요

    my $new = $dir . $newbase;

    # macOS 파일시스템(APFS·HFS+)은 정규화 비구분(normalization-insensitive)이라
    # NFD로 저장된 파일도 NFC 이름으로 -e/lstat 검사하면 "존재"로 잡힌다.
    # 즉 단순 -e 검사는 자기 자신을 충돌로 오인해 전부 건너뛴다.
    # 따라서 '진짜 다른 파일'(다른 inode)이 그 이름을 차지한 경우에만 건너뛴다.
    my @cur = lstat($p);
    my @tgt = lstat($new);
    if (@tgt && (!@cur || $tgt[0] != $cur[0] || $tgt[1] != $cur[1])) {
        warn "건너뜀(같은 이름의 다른 항목 존재): $p\n";
        $skipped++;
        next;
    }

    if ($dry) {
        print "[미리보기] $p  →  $new\n";
        $changed++;
    } elsif (rename($p, $new)) {
        print "변경: $p  →  $new\n" if $verbose;
        $changed++;
    } else {
        warn "실패: $p ($!)\n";
        $skipped++;
    }
}

# 4) 요약 / 알림
my $summary = $dry
    ? "미리보기: ${changed}개 변경 예정"
    : "완료: ${changed}개 변경"
        . ($skipped ? ", ${skipped}개 건너뜀" : "");
print "$summary\n";

if ($notify && !$dry) {
    my $msg = $summary;
    $msg =~ s/"/\\"/g;
    system('/usr/bin/osascript', '-e',
           qq{display notification "$msg" with title "NFC 이름 정리"});
}

# 5) Finder에 결과 보여주기 (Quick Action용).
#    선택한 최상위 항목들의 '최종(NFC) 경로'를 Finder에서 보여준다.
#    - 폴더 하나만 선택했으면 그 폴더를 열어 정리된 내용을 바로 보여줌
#    - 그 외엔 해당 항목들을 선택 상태로 표시(reveal)
if ($reveal && !$dry) {
    my @final;
    for my $arg (@inputs) {
        (my $a = $arg) =~ s{/+$}{};
        next if $a eq '';
        my $i = rindex($a, '/');
        my $dir  = $i < 0 ? '' : substr($a, 0, $i + 1);
        my $base = $i < 0 ? $a : substr($a, $i + 1);
        my $u = eval { my $c = $base; decode_utf8($c, Encode::FB_CROAK) };
        my $fb = defined $u ? encode_utf8(NFC($u)) : $base;
        my $fp = $dir . $fb;
        $fp = $a unless -e $fp;        # 이름이 안 바뀌었으면 원본
        my $abs = eval { require Cwd; Cwd::abs_path($fp) };
        push @final, $abs if defined $abs && -e $abs;
    }
    reveal_in_finder(@final) if @final;
}

# 주어진 절대경로들을 Finder에서 보여준다(폴더 1개면 열기, 그 외엔 선택).
sub reveal_in_finder {
    my @paths = @_;
    my $esc = sub { my $p = shift; $p =~ s/\\/\\\\/g; $p =~ s/"/\\"/g; $p };
    my $script;
    if (@paths == 1 && -d $paths[0]) {
        my $p = $esc->($paths[0]);
        $script = qq{tell application "Finder"\nactivate\nopen (POSIX file "$p" as alias)\nend tell};
    } else {
        my $list = join(", ", map { 'POSIX file "' . $esc->($_) . '"' } @paths);
        $script = qq{tell application "Finder"\nactivate\nreveal {$list}\nend tell};
    }
    system('/usr/bin/osascript', '-e', $script);
}
